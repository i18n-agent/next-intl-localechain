{
  "name": "next-intl-localechain",
  "version": "0.1.0",
  "description": "Smart locale fallback chains for next-intl",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "peerDependencies": {
    "next-intl": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "next-intl": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "tsup": "^8.0.0"
  },
  "keywords": ["next-intl", "i18n", "locale", "fallback", "chain", "localization", "internationalization"],
  "author": "i18nagent.ai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/i18n-agent/next-intl-localechain"
  },
  "homepage": "https://github.com/i18n-agent/next-intl-localechain#readme"
}
